# Quarto build output
/_site/
/.quarto/
**/*.quarto_ipynb
*_files/

# Generated data — produced by scripts/generate_data.py; not committed.
# Use /data/* (not /data/) so exceptions below are honoured by git.
/data/*
!/data/bayesian_gender.json
# Cold-response CSVs generated by R analysis — commit so the live site can load them.
!/data/season_rug.csv
!/data/cold_response_binned_by_winter_sc.csv
!/data/season_curves_fam.csv
!/data/season_curves_sc.csv
!/data/last_pull_date.txt
!/data/last_pull_hash.txt
# CKAN metadata_modified sentinel — committed so the guard job can detect a
# no-change run and skip the expensive CKAN pull + Quarto rebuild.
!/data/last_ckan_modified.txt
# Monthly SSF / Central Intake month markers — committed so refresh-site-data.yml
# can tell when a new month has landed and notify exactly once.
!/data/last_ssf_month.txt
!/data/last_intake_month.txt
# Bridging & Triage scraped daily from City census page — committed to main
# so each CI run can accumulate entries from previous runs.
!/data/city_bridging_triage.json

# Claude Code — local session data and project memory
.claude/
# Claude Code instructions — local only
CLAUDE.md

# Internal dev notes — must not appear in public repo
DailyOccupancy_gh_sync.md
/handoffs/

# Local-only Bayesian R analysis — writes data/bayesian_gender.json (which is committed).
# The R script itself runs locally; no CI invokes it.
scripts/bayesian_gender_brms.R

# Python bytecode
__pycache__/
*.pyc

# macOS
.DS_Store

# Quarto preview/temp files
projects/_*.qmd
projects/_*.html
projects/*-preview.html
